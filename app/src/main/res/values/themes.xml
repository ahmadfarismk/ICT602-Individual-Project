<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - LIGHT ONLY (no dark mode per assignment requirement) -->
    <style name="Base.Theme.IndividualAssignmentProject" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Secondary / Accent -->
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSecondary">@color/colorAccent</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="android:textColorHint">@color/colorTextHint</item>

        <!-- Error color -->
        <item name="colorError">@color/colorError</item>
    </style>

    <style name="Theme.IndividualAssignmentProject" parent="Base.Theme.IndividualAssignmentProject" />

    <!-- Toolbar style -->
    <style name="ToolbarTheme" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>
</resources>