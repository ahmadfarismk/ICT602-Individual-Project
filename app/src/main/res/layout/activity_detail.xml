<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    tools:context=".DetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            android:theme="@style/ToolbarTheme"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/title_detail"
            app:titleTextColor="@color/white" />

        <!-- Detail Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/colorCardStroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/title_detail"
                    android:textColor="@color/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Month (View mode) -->
                <TextView
                    android:id="@+id/tvDetailMonthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_month"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailMonth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="January" />

                <!-- Month (Edit mode) -->
                <Spinner
                    android:id="@+id/spinnerDetailMonth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:entries="@array/months_array"
                    android:padding="8dp"
                    android:spinnerMode="dropdown"
                    android:visibility="gone" />

                <!-- Units Used -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_units"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="250 kWh" />

                <!-- Units (Edit mode) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDetailUnits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:errorEnabled="true"
                    app:helperText="Enter units between 1 and 1000"
                    app:helperTextTextColor="@color/colorTextHint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDetailUnits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_units"
                        android:inputType="number"
                        android:maxLength="4" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Rebate -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_rebate"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailRebate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="5%" />

                <!-- Rebate (Edit mode) -->
                <RadioGroup
                    android:id="@+id/radioGroupDetailRebate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <RadioButton
                        android:id="@+id/rbDetailRebate0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_0"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbDetailRebate1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_1"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbDetailRebate2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_2"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbDetailRebate3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_3"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbDetailRebate4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_4"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/rbDetailRebate5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rebate_5"
                        android:textSize="13sp" />
                </RadioGroup>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/colorDivider" />

                <!-- Total Charges -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_charges"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailTotalCharges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="RM 60.30" />

                <!-- Final Cost -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_final_cost"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDetailFinalCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorAccent"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="RM 57.29" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons (View mode) -->
        <LinearLayout
            android:id="@+id/layoutViewButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/btn_edit"
                android:textColor="@color/colorPrimary"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="@color/colorPrimary"
                app:strokeColor="@color/colorPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/btn_delete"
                android:textColor="@color/colorError"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="@color/colorError"
                app:strokeColor="@color/colorError" />
        </LinearLayout>

        <!-- Action Buttons (Edit mode) -->
        <LinearLayout
            android:id="@+id/layoutEditButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/btn_save"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/btn_cancel"
                android:textColor="@color/colorTextSecondary"
                app:cornerRadius="8dp"
                app:strokeColor="@color/colorTextSecondary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
